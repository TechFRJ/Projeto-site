# Application
NODE_ENV=production
PORT=3000

# Database
DB_TYPE=sqlite
DB_PATH=/data/database.sqlite3

# Session (use a long random string in production)
SESSION_SECRET=change-me-to-a-random-string

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Email (Nodemailer — use Gmail app password or SMTP service)
EMAIL_USER=
EMAIL_PASS=
CONTACT_EMAIL=

# WhatsApp — country code + number, no spaces (e.g. 5511999998888)
WHATSAPP_NUMBER=55XXXXXXXXXXX

# Admin — comma-separated list of authorized Google/GitHub emails
AUTHORIZED_ADMINS=admin@example.com

# AI (Anthropic) — for "Melhorar com IA" feature in quote modal
ANTHROPIC_API_KEY=sk-ant-...
AI_API_URL=https://api.anthropic.com
